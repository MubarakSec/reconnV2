# ╔═══════════════════════════════════════════════════════════╗
# ║             ReconnV2 Environment Configuration             ║
# ╚═══════════════════════════════════════════════════════════╝

# --- API Keys ---
# SecurityTrails: Required for historical DNS origin discovery
RECON_SECURITYTRAILS_API_KEY=

# GitHub Token: Required for GitHub repository secret scanning
RECON_GITHUB_TOKEN=

# ViewDNS: Used for reverse WHOIS lookups
RECON_VIEWDNS_API_KEY=

# WPScan Token: Required for deep WordPress vulnerability scanning
RECON_WPSCAN_API_TOKEN=

# --- Telegram Bot ---
# Create via @BotFather on Telegram
RECON_TELEGRAM_TOKEN=
# Get your ID via /scan command or @userinfobot
RECON_TELEGRAM_CHAT_ID=

# --- Performance & Tuning ---
# RECON_MAX_GLOBAL_CONCURRENCY=20
# RECON_HTTPX_THREADS=50
# RECON_MAX_FUZZ_HOSTS=5
# RECON_LOG_LEVEL=INFO
